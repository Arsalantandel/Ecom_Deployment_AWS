{
  "name": "store",
  "version": "1.0.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "node server/main.js",
    "server": "nodemon server/main.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "data:import": "node server/seeder.js",
    "data:destroy": "node server/seeder.js -d"
  },
  "imports": {
    "#config/*": "./server/config/*",
    "#data/*": "./server/data/*",
    "#models/*": "./server/models/*",
    "#routes/*": "./server/routes/*",
    "#middlewares/*": "./server/middlewares/*",
    "#controllers/*": "./server/controllers/*",
    "#utils/*": "./server/utils/*"
  },
  "author": "Saif Tandel",
  "license": "UNLICENSED",
  "description": "",
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.20.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11"
  }
}
